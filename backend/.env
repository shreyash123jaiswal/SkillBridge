# ─────────────────────────────────────────────
# SkillBridge Backend – Environment Variables
# ─────────────────────────────────────────────

# Server
PORT=5000
NODE_ENV=development

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d

 ServiceAI_SERVICE_URL=http://localhost:8000

# PostgreSQL (leave blank to use in-memory fallback)
DATABASE_URL=postgresql://postgres:postasdf@localhost:5432/skillbridge
DB_HOST=localhost
DB_PORT=5432
DB_NAME=skillbridge
DB_USER=postgres
DB_PASSWORD=postasdf

# File uploads
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=10

# CORS
CORS_ORIGIN=http://localhost:3000

